# Copy this file to .env and fill in real values. Never commit the real .env.

# ── Anthropic (required) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── Twilio (required for WhatsApp) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
VALIDATE_TWILIO_SIGNATURE=false

# ── Public URLs ─────────────────────────────────────────────────────
# Backend ngrok URL for media/PDF delivery during dev.
MEDIA_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app
# Dashboard URL where /action/<token> landing pages live. Use localhost
# for local dev; the deployed URL (e.g. https://your-app.vercel.app) in prod.
DASHBOARD_BASE_URL=http://localhost:3000

# ── Twilio Voice (Browser calling) ──────────────────────────────────
# Create at console.twilio.com > Account > API Keys
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=REPLACE_ME
# Create TwiML App at console.twilio.com > Voice > TwiML Apps
# Set Voice Request URL to: https://<ngrok>/api/voice/twiml
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dedicated Twilio voice number for outbound calls (NOT the WhatsApp sandbox).
TWILIO_VOICE_NUMBER=+15555550123

# ── OpenAI (voice transcription + TTS) ──────────────────────────────
OPENAI_API_KEY=sk-proj-REPLACE_ME
VOICE_REPLIES_ENABLED=true
TTS_MODEL=tts-1
TTS_VOICE=nova

# ── Message mode ────────────────────────────────────────────────────
# "split" sends each block as a separate WhatsApp message (demo feel).
# "compact" sends one consolidated message (saves Twilio quota).
MESSAGE_MODE=compact
